# Copy to .env and adjust paths if your workspace layout differs.
# Default assumes Garbo-infra sits beside the app repos in the same parent folder.

COMPOSE_PROJECT_NAME=garbo-local

# Build-time / runtime API URL for the Next.js dashboard (browser calls this)
NEXT_PUBLIC_API_BASE=http://localhost:8081

# Backend env file (must exist — never commit real secrets)
BACKEND_ENV_FILE=../../Garbo_backend/.env
