# Copy to terraform.tfvars and adjust values.
# terraform.tfvars is gitignored — never commit secrets.

aws_region         = "ap-south-1"
project_name       = "garbo"
environment        = "prod"
instance_type      = "t3.medium"
key_name           = "garbo-deploy-ke"
ssh_allowed_cidr   = "YOUR_PUBLIC_IP/32"
ssm_parameter_prefix = "/garbo/prod"
